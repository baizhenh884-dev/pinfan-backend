# 本地开发配置样板文件
# 复制本文件为 application-dev.yml 并填入你自己的真实凭据
# application-dev.yml 已在 .gitignore 中忽略，不会被提交

spring:
  datasource:
    type: com.alibaba.druid.pool.DruidDataSource
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/pinfan?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: <YOUR_MYSQL_PASSWORD>
    druid:
      initial-size: 5
      min-idle: 5
      max-active: 20
      max-wait: 60000

  redis:
    host: localhost
    port: 6379
    # password: <YOUR_REDIS_PASSWORD>  # 没设密码就注释掉
    database: 0
    timeout: 5000ms
    lettuce:
      pool:
        max-active: 8
        max-idle: 8
        min-idle: 0
